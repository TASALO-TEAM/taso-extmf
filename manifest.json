{
  "manifest_version": 3,
  "name": "TASALO — Tasas de Cambio Cuba",
  "short_name": "TASALO",
  "version": "0.1.0",
  "description": "Tasas de cambio Cuba - El Toque, BCC, Binance. ¡Versión Firefox!",
  "default_locale": "es",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TASALO — Tasas de Cambio"
  },
  "background": {
    "scripts": ["src/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "omnibox": {
    "keyword": "tsl"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://tasalo.duckdns.org/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tasalo@tasalo.app",
      "strict_min_version": "109.0"
    }
  }
}
